# ═══════════════════════════════════════════
#   Project ZEON — Environment Configuration
# ═══════════════════════════════════════════

# ── Mode ────────────────────────────────────
ZEON_ENV=development
ZEON_DEV_AUTO_APPROVE=true        # Auto-approve destructive actions in dev

# ── LLM Backend ─────────────────────────────
ZEON_LLM_BACKEND=ollama           # ollama | llamacpp
ZEON_LLM_MODEL=gemma4:latest      # Active model (already in Ollama)
# Alt: ZEON_LLM_MODEL=qwen3.5-9b  (register with: ollama create qwen3.5-9b -f config/Modelfile.qwen35)
ZEON_LLM_HOST=http://localhost:11434
ZEON_LLM_CONTEXT_WINDOW=32768
ZEON_LLM_TEMPERATURE=0.7

# ── GGUF path (for llama-cpp-python fallback) ─
ZEON_GGUF_PATH=D:/Y32/Programss/Zeon/models/HauhauCS/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q6_K.gguf

# ── Qdrant ───────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_IN_MEMORY=true               # true = in-process (no Docker needed)

# ── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=zeon_neo4j_pass
NEO4J_USE_EMBEDDED=false            # set true if no Neo4j server

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USE_MEMORY=true               # true = use in-process dict fallback

# ── SQLite ───────────────────────────────────
SQLITE_PATH=D:/Y32/Programss/Ongoing/Zeon/data/sqlite/zeon.db

# ── Voice ────────────────────────────────────
ZEON_VOICE_ENABLED=false          # Enable after Phase 5
ZEON_WAKE_WORD=hey zeon
ZEON_VOICE_LANGUAGES=en,hi
WHISPER_MODEL_SIZE=base             # tiny|base|small|medium
ZEON_TTS_ENGINE=piper             # piper | misotts

# ── Paths ────────────────────────────────────
ZEON_ROOT=D:/Y32/Programss/Ongoing/Zeon
ZEON_LOGS_DIR=D:/Y32/Programss/Ongoing/Zeon/data/logs
ZEON_SKILLS_DIR=D:/Y32/Programss/Ongoing/Zeon/skills_registry
ZEON_IMPROVEMENTS_DIR=D:/Y32/Programss/Ongoing/Zeon/improvements

# ── Embeddings ───────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Security ─────────────────────────────────
ZEON_AUDIT_ALL_ACTIONS=true
ZEON_MAX_PLAN_REVISION_LOOPS=3
ZEON_CRITIC_MIN_SCORE=7
