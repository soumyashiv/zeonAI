# ═══════════════════════════════════════════
#   Project JARVIS — Environment Configuration
# ═══════════════════════════════════════════

# ── Mode ────────────────────────────────────
JARVIS_ENV=development
JARVIS_DEV_AUTO_APPROVE=true        # Auto-approve destructive actions in dev

# ── LLM Backend ─────────────────────────────
JARVIS_LLM_BACKEND=ollama           # ollama | llamacpp
JARVIS_LLM_MODEL=gemma4:latest      # Active model (already in Ollama)
# Alt: JARVIS_LLM_MODEL=qwen3.5-9b  (register with: ollama create qwen3.5-9b -f config/Modelfile.qwen35)
JARVIS_LLM_HOST=http://localhost:11434
JARVIS_LLM_CONTEXT_WINDOW=32768
JARVIS_LLM_TEMPERATURE=0.7

# ── GGUF path (for llama-cpp-python fallback) ─
JARVIS_GGUF_PATH=D:/Y32/Programss/Zeon/models/HauhauCS/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q6_K.gguf

# ── Qdrant ───────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_IN_MEMORY=true               # true = in-process (no Docker needed)

# ── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=jarvis_neo4j_pass
NEO4J_USE_EMBEDDED=false            # set true if no Neo4j server

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USE_MEMORY=true               # true = use in-process dict fallback

# ── SQLite ───────────────────────────────────
SQLITE_PATH=D:/Y32/Programss/Ongoing/Zeon/data/sqlite/jarvis.db

# ── Voice ────────────────────────────────────
JARVIS_VOICE_ENABLED=false          # Enable after Phase 5
JARVIS_WAKE_WORD=hey jarvis
JARVIS_VOICE_LANGUAGES=en,hi
WHISPER_MODEL_SIZE=base             # tiny|base|small|medium
JARVIS_TTS_ENGINE=piper             # piper | misotts

# ── Paths ────────────────────────────────────
JARVIS_ROOT=D:/Y32/Programss/Ongoing/Zeon
JARVIS_LOGS_DIR=D:/Y32/Programss/Ongoing/Zeon/data/logs
JARVIS_SKILLS_DIR=D:/Y32/Programss/Ongoing/Zeon/skills_registry
JARVIS_IMPROVEMENTS_DIR=D:/Y32/Programss/Ongoing/Zeon/improvements

# ── Embeddings ───────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Security ─────────────────────────────────
JARVIS_AUDIT_ALL_ACTIONS=true
JARVIS_MAX_PLAN_REVISION_LOOPS=3
JARVIS_CRITIC_MIN_SCORE=7
